    "abstraction_levels": ["concrete", "abstract", "any"],
    "difficulty_levels": ["EMERGING", "DEVELOPING", "EXPANDING", "MASTERING"],
    "interaction_types": ["passive", "interactive", "assessment", "social"]
  },


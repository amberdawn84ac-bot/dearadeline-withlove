  "_meta": {
    "version": "1.0.0",
    "description": "Intelligent Content Tagging registry — every component the brain can emit via GENUI_ASSEMBLY blocks, tagged with modality, abstraction, difficulty, and concept affinity. Used by component_selector.py to match the right component to each student's learning profile.",

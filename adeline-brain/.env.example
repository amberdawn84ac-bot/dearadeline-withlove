# adeline-brain — environment variables
# Copy to .env and fill in values. Never commit .env.

# ── Environment ──────────────────────────────────────────────────────────────
# Set to "production" to enforce strict credential checks (no fallback defaults)
ADELINE_ENV=development

# ── PostgreSQL + pgvector (Hippocampus) ───────────────────────────────────────
POSTGRES_DSN=postgresql://adeline:adeline@localhost:5432/adeline_dev

# ── Neo4j (GraphRAG knowledge graph) ─────────────────────────────────────────
# Local Docker:
#   NEO4J_URI=bolt://localhost:7687
#   NEO4J_USER=neo4j
#   NEO4J_PASSWORD=adeline_local_dev
#
# Neo4j Aura (cloud) — use these instead:
NEO4J_URI=neo4j+s://YOUR_AURA_INSTANCE.databases.neo4j.io
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=
NEO4J_DATABASE=neo4j
AURA_INSTANCEID=
AURA_INSTANCENAME=

# ── Redis (session cache + daily-bread cache) ─────────────────────────────────
# Upstash Redis REST (cloud) — preferred:
UPSTASH_REDIS_REST_URL=https://YOUR_DB.upstash.io
UPSTASH_REDIS_REST_TOKEN=

# Local Docker fallback (used when UPSTASH_REDIS_REST_URL is not set):
# REDIS_URL=redis://localhost:6379

# ── OpenAI (embeddings: text-embedding-3-small) ───────────────────────────────
OPENAI_API_KEY=sk-...

# ── Anthropic (lesson generation: claude-sonnet-4-6) ─────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Tavily (Researcher tool — web archive search) ────────────────────────────
TAVILY_API_KEY=tvly-...

# ── Supabase Storage (EPUB book files) ───────────────────────────────────────
# Set both to use Supabase Storage. Omit for local filesystem storage.
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── App ───────────────────────────────────────────────────────────────────────
# Allowed CORS origins (comma-separated)
CORS_ORIGINS=http://localhost:3000

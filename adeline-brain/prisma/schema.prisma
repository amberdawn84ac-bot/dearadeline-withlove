generator client {
  provider = "prisma-client-py"
  interface = "asyncio"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
}

model User {
  id                   String            @id @default(uuid())
  name                 String
  email                String
  role                 UserRole
  isHomestead          Boolean           @default(false)
  gradeLevel           String?
  mathLevel            Int?
  elaLevel             Int?
  scienceLevel         Int?
  historyLevel         Int?
  interests            String[]
  learningStyle        String?
  pacingMultiplier     Float?
  state                String?
  targetGraduationYear Int?
  onboardingComplete   Boolean           @default(false)
  parentId             String?
  parentName           String?
  parentEmail          String?
  coppaVerified        Boolean           @default(false)
  coppaPendingToken    String?           @unique
  coppaTokenExpiresAt  DateTime?
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt
  standardMastery      StandardMastery[]
}

model Lesson {
  id               String   @id @default(uuid())
  title            String
  estimatedMinutes Int
  targetGrades     String[]
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model LessonTrack {
  lessonId String
  track    Track

  @@id([lessonId, track])
}

model LessonBlock {
  id                 String          @id @default(uuid())
  lessonId           String
  track              Track
  blockType          BlockType
  difficulty         DifficultyLevel
  order              Int
  title              String
  content            String
  isSilenced         Boolean         @default(false)
  tags               String[]
  homesteadEnabled   Boolean         @default(false)
  homesteadContent   String?
  homesteadPractical String?
  createdAt          DateTime        @default(now())
}

model Evidence {
  id                  String          @id @default(uuid())
  blockId             String
  sourceTitle         String
  sourceUrl           String
  similarityScore     Float
  verdict             EvidenceVerdict
  chunk               String
  retrievedAt         DateTime
  citationAuthor      String
  citationYear        Int
  citationArchiveName String
}

model StudentLesson {
  studentId   String
  lessonId    String
  startedAt   DateTime  @default(now())
  completedAt DateTime?

  @@id([studentId, lessonId])
}

model CanonicalLesson {
  id                  String        @id @default(uuid())
  topicSlug           String        @unique
  topic               String
  track               Track
  title               String
  blocksJson          Json
  oasStandards        Json          @default("[]")
  researcherActivated Boolean       @default(false)
  agentName           String        @default("")
  generatedAt         DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
  pendingApproval     Boolean       @default(false)
  atomicUnits         AtomicUnit[]
}

/// An Atomic Learning Unit — the smallest teachable concept within a CanonicalLesson.
/// Each ALU contains one learning objective and carries metadata that drives adaptive routing.
/// A CanonicalLesson is a playlist of ordered ALUs; each ALU's blocks are its multimodal views.
model AtomicUnit {
  id                              String   @id @default(uuid())
  /// Stable slug, e.g. "circular-orbital-velocity" — used as prerequisite reference key
  unitSlug                        String   @unique
  title                           String
  lessonId                        String
  lesson                          CanonicalLesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  track                           Track
  difficulty                      DifficultyLevel @default(DEVELOPING)
  /// Ordered position within the parent lesson playlist (0-based)
  order                           Int      @default(0)
  /// Estimated cognitive load 0.0–10.0 (used by CognitiveLoadBudget to gate delivery)
  estimatedCognitiveLoad          Float    @default(5.0)
  /// Learning modalities this ALU targets, e.g. ["visual","kinesthetic"]
  targetModalities                String[]
  /// Slugs of AtomicUnits that must be mastered before this one is unlocked
  prerequisiteUnitSlugs           String[] @default([])
  /// Seconds of student inactivity/stalling that triggers a Temporal Friction pivot
  temporalFrictionThresholdSecs   Int      @default(45)
  /// Max incorrect attempts before scaffold is injected (0 = inject immediately on first wrong)
  maxIncorrectBeforeScaffold      Int      @default(1)
  /// Component type to stream as remediation (e.g. "FocusReset", "TaskScaffold")
  scaffoldComponent               String   @default("FocusReset")
  /// JSON props passed to the scaffold component
  scaffoldProps                   Json     @default("{}")
  createdAt                       DateTime @default(now())
  updatedAt                       DateTime @updatedAt

  @@index([lessonId])
  @@index([track])
  @@index([unitSlug])
}

model InviteCode {
  id             String   @id @default(uuid())
  code           String
  isUsed         Boolean  @default(false)
  claimedByEmail String?
  createdAt      DateTime @default(now())
}

model Subscription {
  id                   String    @id @default(uuid())
  userId               String    @unique
  stripeCustomerId     String?
  stripeSubscriptionId String?
  stripePriceId        String?
  tier                 String    @default("FREE")
  status               String    @default("ACTIVE")
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean   @default(false)
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
}

model LearningRecord {
  id            String     @id @default(uuid())
  studentId     String
  lessonId      String
  blockId       String?
  verb          XAPIVerb
  objectId      String
  objectName    String
  track         Track
  oasStandard   String     @default("")
  gradeLevel    String     @default("")
  isHomestead   Boolean    @default(false)
  agentName     AgentName?
  blockType     String     @default("")
  durationMs    Int?
  completion    Boolean    @default(false)
  response      String?
  scoreRaw      Float?
  scoreMin      Float?
  scoreMax      Float?
  statementJson Json       @default("{}")
  timestamp     DateTime   @default(now())
  createdAt     DateTime   @default(now())
}

model TranscriptEntry {
  id                  String       @id @default(uuid())
  studentId           String
  lessonId            String
  courseTitle         String
  track               Track
  oasStandards        String[]     @default([])
  activityDescription String       @default("")
  creditHours         Float        @default(0.0)
  creditType          CreditType   @default(ELECTIVE)
  gradeLetter         GradeLetter?
  percentScore        Float?
  isHomesteadCredit   Boolean      @default(false)
  agentName           AgentName?
  researcherActivated Boolean      @default(false)
  completedAt         DateTime     @default(now())
  sealedAt            DateTime?
  xapiStatementId     String?
  createdAt           DateTime     @default(now())
}

model SpacedRepetitionCard {
  id             String    @id @default(uuid())
  studentId      String
  conceptId      String
  conceptName    String
  track          Track
  interval       Int       @default(1)
  easeFactor     Float     @default(2.5)
  repetitions    Int       @default(0)
  lastQuality    Int?
  masteryLevel   Float     @default(0.0)
  dueAt          DateTime  @default(now())
  lastReviewedAt DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model StandardMastery {
  id             String              @id @default(dbgenerated("gen_random_uuid()"))
  studentId      String
  standardId     String
  subject        String
  grade          Int
  proficiency    OASProficiencyLevel @default(DEVELOPING)
  evidenceCount  Int                 @default(0)
  lastEvidenceAt DateTime?
  lastAssessedAt DateTime            @default(now())
  student        User                @relation(fields: [studentId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([studentId, standardId], map: "StandardMastery_unique_student_standard")
  @@index([studentId])
  @@index([standardId])
  @@index([subject, grade])
  @@index([proficiency])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model OASStandard {
  id                  String   @default(dbgenerated("gen_random_uuid()"))
  code                String   @unique
  subject             String
  grade               Int
  gradeBand           String
  strand              String
  description         String
  track               String
  lessonHook          String?
  homesteadAdaptation String?
  difficulty          String   @default("EMERGING")
  createdAt           DateTime @default(now())

  @@index([subject, grade])
  @@index([track])
}

model Book {
  id              String   @id @default(uuid())
  title           String
  author          String
  description     String?
  track           Track
  gradeBand       String?  // JSON array like "[7,12]"
  lexileLevel     Int?
  coverImageUrl   String?
  sourceUrl       String?  // Amazon, publisher, etc.
  isbn            String?
  totalPages      Int?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  readingSessions ReadingSession[]
  
  @@index([track])
  @@index([title])
}

model ReadingSession {
  id              String    @id @default(uuid())
  studentId       String
  bookId          String
  book            Book      @relation(fields: [bookId], references: [id])
  status          String    @default("reading") // reading, completed, paused
  currentLocation String?   // Page, chapter, or location string
  pagesRead       Int       @default(0)
  totalPages      Int?
  minutesRead     Int       @default(0)
  startedAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  completedAt     DateTime?
  
  @@unique([studentId, bookId])
  @@index([studentId])
  @@index([bookId])
}

enum UserRole {
  STUDENT
  PARENT
  ADMIN
}

enum Track {
  CREATION_SCIENCE
  HEALTH_NATUROPATHY
  HOMESTEADING
  GOVERNMENT_ECONOMICS
  JUSTICE_CHANGEMAKING
  DISCIPLESHIP
  TRUTH_HISTORY
  ENGLISH_LITERATURE
  APPLIED_MATHEMATICS
  CREATIVE_ECONOMY
}

enum BlockType {
  TEXT
  NARRATIVE
  PRIMARY_SOURCE
  LAB_MISSION
  EXPERIMENT
  RESEARCH_MISSION
  QUIZ
  DATA_TRACKING
  PROBLEM
  WRITING
  SIMULATION
  VIDEO
  TEXT_DEEP
  REAL_WORLD_APP
  CORRECTIVE_OVERLAY
  CONCEPT_MAP
}

enum XAPIVerb {
  experienced
  completed
  attempted
  passed
  failed
  scored
  interacted
  created
  shared
  observed
  practiced
  researched
  sealed
  focus_gap_detected
  assessed
}

enum CreditType {
  CORE
  ELECTIVE
  PHYSICAL_ED
  FINE_ARTS
  HOMESTEAD
}

enum CreditBucket {
  ENGLISH_CORE
  MATH_CORE
  SCIENCE_CORE
  SOCIAL_STUDIES
  WORLD_LANGUAGE
  PERSONAL_FINANCE
  FINE_ARTS
  ELECTIVES
}

enum GradeLetter {
  A_PLUS
  A
  A_MINUS
  B_PLUS
  B
  B_MINUS
  C_PLUS
  C
  C_MINUS
  D_PLUS
  D
  D_MINUS
  F
  PASS
  FAIL
  INCOMPLETE
}

enum AgentName {
  HistorianAgent
  ScienceAgent
  DiscipleshipAgent
  RegistrarAgent
}

enum EvidenceVerdict {
  VERIFIED
  ARCHIVE_SILENT
  RESEARCH_MISSION
}

enum DifficultyLevel {
  EMERGING
  DEVELOPING
  EXPANDING
  MASTERING
}

enum OASProficiencyLevel {
  DEVELOPING
  APPROACHING
  UNDERSTANDING
  EXTENDING
}

/// Component Interaction Log — training data for ML component selector.
/// Records every student interaction with a GenUI component to build
/// a collaborative filtering model that predicts optimal component choices.
model ComponentInteractionLog {
  id                String   @id @default(uuid())
  studentId         String
  componentId       String   // e.g. "AudioDialogue", "MindMap", "QuizCard"
  componentType     String   // category: "multimodal", "assessment", "scaffolding", etc.
  lessonId          String?
  aluUnitSlug       String?  // which ALU this interaction occurred in
  track             Track
  /// Interaction type: "viewed", "completed", "struggled", "skipped", "scaffold_triggered"
  interactionType   String
  /// Student's preferred modality at time of interaction
  studentModality   String?  // "visual", "auditory", "kinesthetic", "text", "reading"
  /// Component's modalities (from registry)
  componentModalities String[] @default([])
  /// Difficulty band of the component
  difficulty        String   @default("DEVELOPING")
  /// Time spent on this component (seconds)
  durationSecs      Float?
  /// Whether the student successfully completed this component
  completed         Boolean  @default(false)
  /// Number of incorrect answers / struggles
  struggleCount     Int      @default(0)
  /// Hints used
  hintsUsed         Int      @default(0)
  /// Mastery score before this interaction (from BKT)
  masteryBefore     Float?
  /// Mastery score after this interaction
  masteryAfter      Float?
  /// Context metadata (JSON for flexibility)
  context           Json     @default("{}")
  timestamp         DateTime @default(now())

  @@index([studentId])
  @@index([componentId])
  @@index([track])
  @@index([aluUnitSlug])
  @@index([timestamp])
  @@index([studentId, componentId])
}

/// Hippocampus Documents — curriculum content seeded for similarity search.
/// Stores the primary sources, narratives, and other content used by the
/// Witness Protocol and the knowledge graph.
model HippocampusDocument {
  id          String   @id @default(uuid())
  title       String
  content     String   @db.Text
  sourceUrl   String?
  sourceType  String   @default("PRIMARY_SOURCE")
  track       Track
  oasStandard String?
  embedding   Json?    // pgvector embedding for similarity search
  metadata    Json     @default("{}")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([track])
  @@index([oasStandard])
  @@index([sourceType])
}

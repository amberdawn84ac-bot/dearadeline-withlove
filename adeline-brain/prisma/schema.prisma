// adeline-brain/prisma/schema.prisma
// Mirrors adeline-core/src/types.ts — source of truth for all models.

generator client {
  provider             = "prisma-client-py"
  interface            = "asyncio"
  recursive_type_depth = 5
}

datasource db {
  provider = "postgresql"
  url      = env("POSTGRES_DSN")
}

// ── Enums ─────────────────────────────────────────────────────────────────────

enum UserRole {
  STUDENT
  PARENT
  ADMIN
}

enum Track {
  CREATION_SCIENCE
  HEALTH_NATUROPATHY
  HOMESTEADING
  GOVERNMENT_ECONOMICS
  JUSTICE_CHANGEMAKING
  DISCIPLESHIP
  TRUTH_HISTORY
  ENGLISH_LITERATURE
  APPLIED_MATHEMATICS
  CREATIVE_ECONOMY
}

enum BlockType {
  TEXT
  NARRATIVE
  PRIMARY_SOURCE
  LAB_MISSION
  RESEARCH_MISSION
  QUIZ
}

enum XAPIVerb {
  experienced
  completed
  attempted
  passed
  failed
  scored
  interacted
  created
  shared
  observed
  practiced
  researched
  sealed
}

enum CreditType {
  CORE
  ELECTIVE
  PHYSICAL_ED
  FINE_ARTS
  HOMESTEAD
}

enum GradeLetter {
  A_PLUS
  A
  A_MINUS
  B_PLUS
  B
  B_MINUS
  C_PLUS
  C
  C_MINUS
  D_PLUS
  D
  D_MINUS
  F
  PASS
  FAIL
  INCOMPLETE
}

enum AgentName {
  HistorianAgent
  ScienceAgent
  DiscipleshipAgent
  RegistrarAgent
}

enum EvidenceVerdict {
  VERIFIED
  ARCHIVE_SILENT
  RESEARCH_MISSION
}

enum DifficultyLevel {
  EMERGING
  DEVELOPING
  EXPANDING
  MASTERING
}

// ── Models ────────────────────────────────────────────────────────────────────

model User {
  id          String   @id @default(uuid())
  name        String
  email       String   @unique
  role        UserRole
  isHomestead Boolean  @default(false)
  gradeLevel  String?  // Required when role = STUDENT (enforced in app layer)

  lessons     StudentLesson[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([role])
  @@index([email])
}

model Lesson {
  id               String   @id @default(uuid())
  title            String
  estimatedMinutes Int
  targetGrades     String[]

  tracks  LessonTrack[]
  blocks  LessonBlock[]
  students StudentLesson[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model LessonTrack {
  lessonId String
  track    Track

  lesson   Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@id([lessonId, track])
}

model LessonBlock {
  id         String          @id @default(uuid())
  lessonId   String
  track      Track
  blockType  BlockType
  difficulty DifficultyLevel
  order      Int
  title      String
  content    String
  isSilenced Boolean         @default(false)
  tags       String[]

  homesteadEnabled     Boolean @default(false)
  homesteadContent     String?
  homesteadPractical   String?

  evidence  Evidence[]
  lesson    Lesson     @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([lessonId, order])
  @@index([blockType])
}

model Evidence {
  id              String          @id @default(uuid())
  blockId         String
  sourceTitle     String
  sourceUrl       String
  similarityScore Float
  verdict         EvidenceVerdict
  chunk           String
  retrievedAt     DateTime

  // WitnessCitation fields (flattened from the nested Zod object)
  citationAuthor      String
  citationYear        Int
  citationArchiveName String

  block LessonBlock @relation(fields: [blockId], references: [id], onDelete: Cascade)

  @@index([blockId])
  @@index([verdict])
  @@index([similarityScore])
}

model StudentLesson {
  studentId  String
  lessonId   String
  startedAt  DateTime @default(now())
  completedAt DateTime?

  student User   @relation(fields: [studentId], references: [id])
  lesson  Lesson @relation(fields: [lessonId], references: [id])

  @@id([studentId, lessonId])
}

model InviteCode {
  id             String   @id @default(uuid())
  code           String   @unique
  isUsed         Boolean  @default(false)
  claimedByEmail String?
  createdAt      DateTime @default(now())

  @@index([code])
}

// ── Phase 6: Learning Records, Transcript, Spaced Repetition ─────────────────

model LearningRecord {
  id           String    @id @default(uuid())
  studentId    String
  lessonId     String
  blockId      String?
  verb         XAPIVerb
  objectId     String
  objectName   String
  track        Track
  oasStandard  String    @default("")
  gradeLevel   String    @default("")
  isHomestead  Boolean   @default(false)
  agentName    AgentName?
  blockType    String    @default("")
  durationMs   Int?
  completion   Boolean   @default(false)
  response     String?
  scoreRaw     Float?
  scoreMin     Float?
  scoreMax     Float?
  statementJson Json     @default("{}")
  timestamp    DateTime  @default(now())
  createdAt    DateTime  @default(now())

  @@index([studentId])
  @@index([lessonId])
  @@index([track])
  @@index([verb])
  @@index([timestamp])
}

model TranscriptEntry {
  id                  String      @id @default(uuid())
  studentId           String
  lessonId            String
  courseTitle         String
  track               Track
  oasStandards        String[]    @default([])
  activityDescription String      @default("")
  creditHours         Float       @default(0.0)
  creditType          CreditType  @default(ELECTIVE)
  gradeLetter         GradeLetter?
  percentScore        Float?
  isHomesteadCredit   Boolean     @default(false)
  agentName           AgentName?
  researcherActivated Boolean     @default(false)
  completedAt         DateTime    @default(now())
  sealedAt            DateTime?
  xapiStatementId     String?
  createdAt           DateTime    @default(now())

  @@unique([studentId, lessonId])
  @@index([studentId])
  @@index([track])
  @@index([creditType])
  @@index([completedAt])
}

model SpacedRepetitionCard {
  id             String   @id @default(uuid())
  studentId      String
  conceptId      String
  conceptName    String
  track          Track
  interval       Int      @default(1)
  easeFactor     Float    @default(2.5)
  repetitions    Int      @default(0)
  lastQuality    Int?
  masteryLevel   Float    @default(0.0)
  dueAt          DateTime @default(now())
  lastReviewedAt DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([studentId, conceptId])
  @@index([studentId])
  @@index([dueAt])
  @@index([track])
  @@index([masteryLevel])
}

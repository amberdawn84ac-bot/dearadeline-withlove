generator client {
  provider = "prisma-client-py"
  interface = "asyncio"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                   String            @id @default(uuid())
  name                 String
  email                String
  role                 UserRole
  isHomestead          Boolean           @default(false)
  gradeLevel           String?
  mathLevel            Int?
  elaLevel             Int?
  scienceLevel         Int?
  historyLevel         Int?
  interests            String[]
  learningStyle        String?
  pacingMultiplier     Float?
  state                String?
  targetGraduationYear Int?
  onboardingComplete   Boolean           @default(false)
  parentId             String?
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt
  standardMastery      StandardMastery[]
}

model Lesson {
  id               String   @id @default(uuid())
  title            String
  estimatedMinutes Int
  targetGrades     String[]
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model LessonTrack {
  lessonId String
  track    Track

  @@id([lessonId, track])
}

model LessonBlock {
  id                 String          @id @default(uuid())
  lessonId           String
  track              Track
  blockType          BlockType
  difficulty         DifficultyLevel
  order              Int
  title              String
  content            String
  isSilenced         Boolean         @default(false)
  tags               String[]
  homesteadEnabled   Boolean         @default(false)
  homesteadContent   String?
  homesteadPractical String?
  createdAt          DateTime        @default(now())
}

model Evidence {
  id                  String          @id @default(uuid())
  blockId             String
  sourceTitle         String
  sourceUrl           String
  similarityScore     Float
  verdict             EvidenceVerdict
  chunk               String
  retrievedAt         DateTime
  citationAuthor      String
  citationYear        Int
  citationArchiveName String
}

model StudentLesson {
  studentId   String
  lessonId    String
  startedAt   DateTime  @default(now())
  completedAt DateTime?

  @@id([studentId, lessonId])
}

model CanonicalLesson {
  id                  String   @id @default(uuid())
  topicSlug           String
  topic               String
  track               Track
  title               String
  blocksJson          Json
  oasStandards        Json     @default("[]")
  researcherActivated Boolean  @default(false)
  agentName           String   @default("")
  generatedAt         DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model InviteCode {
  id             String   @id @default(uuid())
  code           String
  isUsed         Boolean  @default(false)
  claimedByEmail String?
  createdAt      DateTime @default(now())
}

model LearningRecord {
  id            String     @id @default(uuid())
  studentId     String
  lessonId      String
  blockId       String?
  verb          XAPIVerb
  objectId      String
  objectName    String
  track         Track
  oasStandard   String     @default("")
  gradeLevel    String     @default("")
  isHomestead   Boolean    @default(false)
  agentName     AgentName?
  blockType     String     @default("")
  durationMs    Int?
  completion    Boolean    @default(false)
  response      String?
  scoreRaw      Float?
  scoreMin      Float?
  scoreMax      Float?
  statementJson Json       @default("{}")
  timestamp     DateTime   @default(now())
  createdAt     DateTime   @default(now())
}

model TranscriptEntry {
  id                  String       @id @default(uuid())
  studentId           String
  lessonId            String
  courseTitle         String
  track               Track
  oasStandards        String[]     @default([])
  activityDescription String       @default("")
  creditHours         Float        @default(0.0)
  creditType          CreditType   @default(ELECTIVE)
  gradeLetter         GradeLetter?
  percentScore        Float?
  isHomesteadCredit   Boolean      @default(false)
  agentName           AgentName?
  researcherActivated Boolean      @default(false)
  completedAt         DateTime     @default(now())
  sealedAt            DateTime?
  xapiStatementId     String?
  createdAt           DateTime     @default(now())
}

model SpacedRepetitionCard {
  id             String    @id @default(uuid())
  studentId      String
  conceptId      String
  conceptName    String
  track          Track
  interval       Int       @default(1)
  easeFactor     Float     @default(2.5)
  repetitions    Int       @default(0)
  lastQuality    Int?
  masteryLevel   Float     @default(0.0)
  dueAt          DateTime  @default(now())
  lastReviewedAt DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model StandardMastery {
  id             String              @id @default(dbgenerated("gen_random_uuid()"))
  studentId      String
  standardId     String
  subject        String
  grade          Int
  proficiency    OASProficiencyLevel @default(DEVELOPING)
  evidenceCount  Int                 @default(0)
  lastEvidenceAt DateTime?
  lastAssessedAt DateTime            @default(now())
  student        User                @relation(fields: [studentId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([studentId, standardId], map: "StandardMastery_unique_student_standard")
  @@index([studentId])
  @@index([standardId])
  @@index([subject, grade])
  @@index([proficiency])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model OASStandard {
  id                  String   @default(dbgenerated("gen_random_uuid()"))
  code                String   @unique
  subject             String
  grade               Int
  gradeBand           String
  strand              String
  description         String
  track               String
  lessonHook          String?
  homesteadAdaptation String?
  difficulty          String   @default("EMERGING")
  createdAt           DateTime @default(now())

  @@index([subject, grade])
  @@index([track])
}

enum UserRole {
  STUDENT
  PARENT
  ADMIN
}

enum Track {
  CREATION_SCIENCE
  HEALTH_NATUROPATHY
  HOMESTEADING
  GOVERNMENT_ECONOMICS
  JUSTICE_CHANGEMAKING
  DISCIPLESHIP
  TRUTH_HISTORY
  ENGLISH_LITERATURE
  APPLIED_MATHEMATICS
  CREATIVE_ECONOMY
}

enum BlockType {
  TEXT
  NARRATIVE
  PRIMARY_SOURCE
  LAB_MISSION
  EXPERIMENT
  RESEARCH_MISSION
  QUIZ
  DATA_TRACKING
  PROBLEM
  WRITING
}

enum XAPIVerb {
  experienced
  completed
  attempted
  passed
  failed
  scored
  interacted
  created
  shared
  observed
  practiced
  researched
  sealed
}

enum CreditType {
  CORE
  ELECTIVE
  PHYSICAL_ED
  FINE_ARTS
  HOMESTEAD
}

enum CreditBucket {
  ENGLISH_CORE
  MATH_CORE
  SCIENCE_CORE
  SOCIAL_STUDIES
  WORLD_LANGUAGE
  PERSONAL_FINANCE
  FINE_ARTS
  ELECTIVES
}

enum GradeLetter {
  A_PLUS
  A
  A_MINUS
  B_PLUS
  B
  B_MINUS
  C_PLUS
  C
  C_MINUS
  D_PLUS
  D
  D_MINUS
  F
  PASS
  FAIL
  INCOMPLETE
}

enum AgentName {
  HistorianAgent
  ScienceAgent
  DiscipleshipAgent
  RegistrarAgent
}

enum EvidenceVerdict {
  VERIFIED
  ARCHIVE_SILENT
  RESEARCH_MISSION
}

enum DifficultyLevel {
  EMERGING
  DEVELOPING
  EXPANDING
  MASTERING
}

enum OASProficiencyLevel {
  DEVELOPING
  APPROACHING
  UNDERSTANDING
  EXTENDING
}

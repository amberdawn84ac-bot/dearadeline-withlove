# adeline-ui — environment variables
# Copy to .env.local and fill in values. Never commit .env.local.

# ── adeline-brain proxy ───────────────────────────────────────────────────────
# Docker internal hostname (used in docker-compose):
BRAIN_INTERNAL_URL=http://adeline-brain:8000
# Local dev override — use this when running pnpm dev directly:
# BRAIN_INTERNAL_URL=http://localhost:8000

# ── Next.js public vars (available in the browser) ───────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Optional: override brain URL from the browser side (leave blank to use /brain proxy)
# NEXT_PUBLIC_BRAIN_URL=http://localhost:8000

# ── Stripe ────────────────────────────────────────────────────────────────────
# Publishable key — safe to expose to the browser
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
# Secret key — server-side only
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Price IDs from your Stripe dashboard (Products → Prices → copy ID)
STRIPE_PRICE_STUDENT_MONTHLY=price_...
STRIPE_PRICE_STUDENT_YEARLY=price_...
STRIPE_PRICE_PARENT_MONTHLY=price_...
STRIPE_PRICE_PARENT_YEARLY=price_...
STRIPE_PRICE_TEACHER_MONTHLY=price_...
STRIPE_PRICE_TEACHER_YEARLY=price_...
STRIPE_PRICE_EXTRA_STUDENT=price_...

# ── Hygraph (Headless CMS — optional) ────────────────────────────────────────
# Leave blank if you haven't set up Hygraph yet — CMS features will show fallbacks
HYGRAPH_ENDPOINT=https://api-ap-northeast-1.hygraph.com/v2/YOUR_PROJECT_ID/master
HYGRAPH_TOKEN=eyJhbGci...

# adeline-ui — environment variables
# Copy to .env.local and fill in values. Never commit .env.local.

# ── adeline-brain proxy ───────────────────────────────────────────────────────
# Internal URL (Docker) — used by Next.js rewrites to /brain/*
BRAIN_INTERNAL_URL=http://adeline-brain:8000
# Dev override (local): BRAIN_INTERNAL_URL=http://localhost:8000

# ── Hygraph (Headless CMS) ────────────────────────────────────────────────────
# Content API endpoint from Hygraph project settings
HYGRAPH_ENDPOINT=https://api-ap-northeast-1.hygraph.com/v2/YOUR_PROJECT_ID/master
# Permanent auth token (Content API — read-only)
HYGRAPH_TOKEN=eyJhbGci...

# ── Next.js ───────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
